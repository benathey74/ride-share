# Node
TZ=UTC
PORT=3333
# With HOST=localhost, Node may listen on IPv6 only (::1). Use http://localhost:3333 in the
# frontend (NEXT_PUBLIC_API_BASE_URL), not http://127.0.0.1:3333, unless you set HOST=127.0.0.1 or 0.0.0.0.
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
# Must be a valid URL (match how clients reach this API).
APP_URL=http://localhost:3333

# Session
SESSION_DRIVER=cookie

# PostgreSQL (local)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=ride_share
# DB_SSL=true

# --- Supabase Postgres (Adonis / Lucid — direct connection, not the Data API) ---
# In Supabase: Project Settings → Database → copy the database password, then either:
#   fill DB_* below, or use the "Direct connection" URI host in DB_HOST.
# Always use SSL for Supabase:
#   DB_SSL=true
# Typical values:
#   DB_HOST=db.<project-ref>.supabase.co
#   DB_PORT=5432
#   DB_USER=postgres
#   DB_PASSWORD=<your-database-password>
#   DB_DATABASE=postgres
# Pooler (IPv4 / serverless): use the "Transaction" pooler host from Supabase if direct fails.
# Example project ref (replace password):
# DB_HOST=db.wzfevvzejgorhmkagxxb.supabase.co
# DB_DATABASE=postgres
# DB_SSL=true
#
# One-off migrations against Supabase from your laptop:
#   cp .env.supabase.example .env.supabase   # add DB_PASSWORD, gitignored
#   bash scripts/migrate-supabase.sh
# Optional seeded logins: ENSURE_ALPHA=1 bash scripts/migrate-supabase.sh

# Optional: Google Directions API (server key). When set, new route templates store
# `route_polyline`, `total_distance_meters`, and `total_duration_seconds` from driving directions.
# Enable "Directions API" for this key in Google Cloud Console.
# GOOGLE_MAPS_SERVER_API_KEY=

# When true (default in development if unset), allow X-User-Id impersonation when no session cookie.
# Set false to require email/password session for all API routes (recommended for staging).
# ALLOW_DEV_IDENTITY_HEADERS=true

#--------------------------------------------------------------------
# CORS — see config/cors.ts (not env-driven here).
# In development, origin is effectively allow-all; production uses an explicit allowlist.
# http://localhost:3000 is therefore allowed while NODE_ENV=development.
#--------------------------------------------------------------------