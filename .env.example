# Next.js frontend — copy to `.env.local` in this same directory (repo / app root).
# Restart `npm run dev` after any change.

# Adonis API base URL (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3333

# --- Supabase Data API (only if you use @supabase/supabase-js or Supabase REST in the browser) ---
# The ride-share app talks to Adonis for product APIs; these are optional for future Supabase client features.
# Project URL: Settings → API → Project URL
# Publishable key: Settings → API → Publishable key (safe for the client; replace before production if leaked)
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>

# Optional dev-only: send X-User-Id for impersonation when NOT signed in (session cookie is primary).
# Set to "true" only for local tooling. Default: omit (no X-User-Id header).
# NEXT_PUBLIC_ALLOW_DEV_IDENTITY_HEADERS=true

# When dev headers are enabled, default X-User-Id if the Dev menu did not override (e.g. 2 = seeded host).
# NEXT_PUBLIC_DEV_USER_ID=2

# --- Google Maps (driver “Create route” place search) ---
# Required for `/routes/new` origin/destination autocomplete. Use a browser key with:
#   Maps JavaScript API + Places API enabled, HTTP referrer restrictions for your dev origin.
# Restart `npm run dev` after setting or changing this value.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
